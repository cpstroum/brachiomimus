# Per-arm settings for the demos, loaded by brachiomimus/config.py.
# These are hardware calibration, not secrets - safe to commit.
# Any real secrets (tokens etc.) belong in .env.local, which is gitignored.
#
# CLI flags on the demos override anything set here.

# Gripper calibration (degrees), found with: python -m demos.dance --read-gripper
BRACHIOMIMUS_GRIPPER_CLOSED_DEG=-61.32
BRACHIOMIMUS_GRIPPER_OPEN_DEG=61.2

# Brachiomimus (follower) enumerates as COM4; the leader Brachius Rex is COM7.
BRACHIOMIMUS_PORT=COM4
# BRACHIOMIMUS_SENSITIVITY=1.8
# BRACHIOMIMUS_INTENSITY=1.0
