# Copy this file to `.env` and fill in your values:
#     Copy-Item .env.example .env    # Windows PowerShell
#     cp .env.example .env           # macOS / Linux
#
# The real `.env` is gitignored — it holds your per-arm calibration AND your
# training secret (the W&B key), so it must never be committed. This template
# is the committed, secret-free version.
#
# `.env` is read in two places:
#   1. the demos, via brachiomimus/config.py            (the BRACHIOMIMUS_* keys)
#   2. cloud training, via `hf jobs run --secrets-file .env`  (WANDB_API_KEY)

# --- Per-arm settings (non-secret hardware calibration) ------------------
# Gripper calibration (degrees) — find yours with:
#     python -m demos.dance --read-gripper
BRACHIOMIMUS_GRIPPER_CLOSED_DEG=-61.32
BRACHIOMIMUS_GRIPPER_OPEN_DEG=61.2

# Brachiomimus (follower) enumerates as COM4; the leader Brachius Rex is COM7.
BRACHIOMIMUS_PORT=COM4
# BRACHIOMIMUS_SENSITIVITY=1.8
# BRACHIOMIMUS_INTENSITY=1.0

# --- Secrets (put REAL values only in .env, which is gitignored) ---------
# Weights & Biases API key, passed to cloud training via `--secrets-file .env`.
# Get it from https://wandb.ai/authorize
WANDB_API_KEY=

# Hugging Face token is usually NOT needed here — if you've run
# `hf auth login`, HF Jobs picks it up via `--secrets HF_TOKEN`.
# Only set this if you need to pass a token explicitly.
# HF_TOKEN=
